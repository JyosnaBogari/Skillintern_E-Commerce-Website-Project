### User Register
POST http://localhost:3000/user-api/users
Content-Type: application/json

{
  "firstName": "Test",
  "lastName": "User",
  "email": "testuser@example.com",
  "password": "Test@123"
}

### User Login
POST http://localhost:3000/common-api/authenticate
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "Test@123"
}

### Admin Login
POST http://localhost:3000/common-api/authenticate
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "Admin@123"
}

### Logout
GET http://localhost:3000/common-api/logout

### Change Password
PUT http://localhost:3000/common-api/change-password
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "Test@123",
  "newpassword": "NewPass@123"
}

### Block User
PUT http://localhost:3000/admin-api/blockuser
Content-Type: application/json

{
  "userId": "USER_ID_HERE"
}

### Unblock User
PUT http://localhost:3000/admin-api/unblockuser
Content-Type: application/json

{
  "userId": "USER_ID_HERE"
}

### Add to Cart
PUT http://localhost:3000/user-api/user-cart/PRODUCT_ID_HERE

### Add Product (Admin)
POST http://localhost:3000/product-api/products
Content-Type: application/json

{
  "name": "Sample Product",
  "description": "Sample description",
  "price": 100,
  "stock": 10,
  "image": "https://via.placeholder.com/150",
  "category": "electronics",
  "brand": "sample brand",
  "isActive": true
}

### Get All Products
GET http://localhost:3000/product-api/products

### Get Product by ID
GET http://localhost:3000/product-api/product-id/PRODUCT_ID_HERE

### Update Product
PUT http://localhost:3000/product-api/update-product/PRODUCT_ID_HERE
Content-Type: application/json

{
  "stock": 50
}

### Delete Product
DELETE http://localhost:3000/admin-api/product-id/PRODUCT_ID_HERE

### Filter by Category
GET http://localhost:3000/product-api/filter-category/electronics

### Get User by ID
GET http://localhost:3000/user-api/users/USER_ID_HERE

### Update User
PUT http://localhost:3000/user-api/update-user/USER_ID_HERE
Content-Type: application/json

{
  "email": "updated@example.com"
}

### Get All Users
GET http://localhost:3000/user-api/users

### Place Order
POST http://localhost:3000/order-api/place-order

### Admin Orders
GET http://localhost:3000/admin-api/orders

### View Cart
GET http://localhost:3000/user-api/user-cart

### Remove from Cart
DELETE http://localhost:3000/user-api/remove-cart/PRODUCT_ID_HERE

