### User Register
POST https://skillintern-e-commerce-website.onrender.com/user-api/users
Content-Type: application/json

{
  "firstName": "Test",
  "lastName": "User",
  "email": "testuser@example.com",
  "password": "Test@123"
}

### User Login
POST https://skillintern-e-commerce-website.onrender.com/common-api/authenticate
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "Test@123"
}

### Admin Login
POST https://skillintern-e-commerce-website.onrender.com/common-api/authenticate
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "Admin@123"
}

### Logout
GET https://skillintern-e-commerce-website.onrender.com/common-api/logout

### Change Password
PUT https://skillintern-e-commerce-website.onrender.com/common-api/change-password
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "Test@123",
  "newpassword": "NewPass@123"
}

### Block User
PUT https://skillintern-e-commerce-website.onrender.com/admin-api/blockuser
Content-Type: application/json

{
  "userId": "USER_ID_HERE"
}

### Unblock User
PUT https://skillintern-e-commerce-website.onrender.com/admin-api/unblockuser
Content-Type: application/json

{
  "userId": "USER_ID_HERE"
}

### Add to Cart
PUT https://skillintern-e-commerce-website.onrender.com/user-api/user-cart/PRODUCT_ID_HERE

### Add Product (Admin)
POST https://skillintern-e-commerce-website.onrender.com/product-api/products
Content-Type: application/json

{
    "name": "Trendy Women's Handbag",
    "description": "Stylish and spacious handbag for daily use, made with durable material and elegant design.",
    "price": 34,
    "stock": 20,
    "image": "https://images.meesho.com/images/products/461021810/wykhk_512.avif?width=360",
    "category": "women's accessories",
    "brand": "Meesho",
    "isActive": true
}

### Get All Products
GET https://skillintern-e-commerce-website.onrender.com/product-api/products

### Get ALL PRODUCTS 
GET https://skillintern-e-commerce-website.onrender.com/product-api/products

### Get Product by ID
GET https://skillintern-e-commerce-website.onrender.com/product-api/product-id/PRODUCT_ID_HERE

### Update Product
PUT https://skillintern-e-commerce-website.onrender.com/product-api/update-product/PRODUCT_ID_HERE
Content-Type: application/json

{
  "stock": 50
}

### Delete Product
DELETE https://skillintern-e-commerce-website.onrender.com/admin-api/product-id/PRODUCT_ID_HERE

### Filter by Category
GET https://skillintern-e-commerce-website.onrender.com/product-api/filter-category/electronics

### Get User by ID
GET https://skillintern-e-commerce-website.onrender.com:3000/user-api/users/USER_ID_HERE

### Update User
PUT https://skillintern-e-commerce-website.onrender.com/user-api/update-user/USER_ID_HERE
Content-Type: application/json

{
  "email": "updated@example.com"
}

### Get All Users
GET http://localhost:3000/user-api/users

